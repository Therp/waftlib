#!/bin/bash
# Version: v.22.05.30

SCRIPT_PATH="$(cd "$(/usr/bin/dirname "${0}")" && /bin/pwd)"
ODOO_WORK_DIR="$(cd "${SCRIPT_PATH}/../.." && /bin/pwd)"
. "${ODOO_WORK_DIR}/.env-default" && \
. "${ODOO_WORK_DIR}/.env-shared" && \
. "${ODOO_WORK_DIR}/.env-secret" && \
. "${ODOO_WORK_DIR}/.venv/bin/activate" && \
cd "${ODOO_WORK_DIR}"

/bin/echo "WARNING unittest is deprecated, use instead: addons update --test ${@}"
# Shortcut to run Odoo in unit testing mode
set -e
addons="${1}"
shift
/bin/echo "INFO Executing Odoo in unittest mode for addons ${addons}"
# HACK `--workers 0`: https://github.com/odoo/odoo/pull/14809
set -x
exec "${ODOO_WORK_DIR}/.venv/bin/odoo" --workers 0 --test-enable --stop-after-init --update "${addons}" "${@}"
